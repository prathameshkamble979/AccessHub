# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:  mongodb://127.0.0.1:27017/accesshub
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/accesshub
MONGODB_URI=mongodb://127.0.0.1:27017/accesshub

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
# Gmail setup:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to Google Account > Security > App Passwords
#   3. Generate an app password for "Mail"
#   4. Paste it below as EMAIL_PASS (not your real Gmail password)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
